# P-StreamRec - Exemple d'environnement
OUTPUT_DIR=/data
PORT=8080
FFMPEG_PATH=ffmpeg
HLS_TIME=4
HLS_LIST_SIZE=6
CB_RESOLVER_ENABLED=true
# Optionnel: cookie de session pour la résolution Chaturbate
# CB_COOKIE="session=...; other=..."
# Optionnel: mot de passe pour protéger l'accès
# PASSWORD=your_secure_password

# Chaturbate Authentication (optional - enables Following page and better stream quality)
# CHATURBATE_USERNAME=your_chaturbate_username
# CHATURBATE_PASSWORD=your_chaturbate_password

# FlareSolverr (optional - Cloudflare bypass, auto-configured with docker-compose)
# FLARESOLVERR_URL=http://flaresolverr:8191
# FLARESOLVERR_MAX_TIMEOUT=60000

# Chaturbate request delay in seconds (rate limiting)
# CB_REQUEST_DELAY=1.0
# AUTO_RECORD_INTERVAL=30
# RECORD_SEGMENT_MINUTES=0
# MONITOR_AUTORECORD_RESTART_COOLDOWN=30
# FFMPEG_RECONNECT_DELAY_MAX=30
# FFMPEG_RECONNECT_ON_HTTP_ERROR=4xx,5xx
# FFMPEG_RECONNECT_AT_EOF=1
# FFMPEG_RW_TIMEOUT_US=15000000

# Conversion behavior
# AUTO_CONVERT_WHILE_RECORDING=false
# CONVERT_MODE=reencode   # reencode | copy | qsv | vaapi
# CONVERT_QSV_DEVICE=/dev/dri/renderD128
# CONVERT_PRESET=medium
# CONVERT_CRF=23
# CONVERT_COPY_AUDIO=true
# CONVERT_AUDIO_BITRATE=128k
# LIBVA_DRIVER_NAME=iHD
