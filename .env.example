# P-StreamRec - Exemple d'environnement
OUTPUT_DIR=/data
PORT=8080
FFMPEG_PATH=ffmpeg
HLS_TIME=4
HLS_LIST_SIZE=6
CB_RESOLVER_ENABLED=true
# Optionnel: cookie de session pour la résolution Chaturbate
# CB_COOKIE="session=...; other=..."

# Télémétrie anonyme (pour compter les instances actives)
# Collecte uniquement: UUID instance, version, timestamp
# Aucune donnée personnelle. Désactiver avec TELEMETRY_DISABLED=true
TELEMETRY_DISABLED=false
TELEMETRY_INTERVAL=86400  # 24h en secondes
